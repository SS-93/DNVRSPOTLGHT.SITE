# Copy to .env.local for local dev. Set the same keys in Vercel for production.
# The app runs without these (dev mode) but won't persist/email until set.
# See docs/SETUP.Vercel-Supabase-Resend.md

# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Resend (email) ──
RESEND_API_KEY=
CONTACT_FROM_EMAIL="Denver Spotlight <info@denverspotlight.org>"
CONTACT_FORWARD_TO=info@denverspotlight.org
